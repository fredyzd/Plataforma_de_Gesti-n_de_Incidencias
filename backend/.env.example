# ============================================================
# PGI — Variables de entorno del Backend
# Copia este archivo como .env y ajusta los valores
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
APP_ENV=qas            # qas | production
APP_PORT=3001

# ── CORS / Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────
# PRODUCCIÓN: usar strings aleatorios de al menos 64 caracteres
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_SECONDS=604800

# ── Seguridad de login ────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RESET_TOKEN_TTL_MINUTES=30
INITIAL_PASSWORD_TOKEN_TTL_MINUTES=15

# ── Usuarios seed (solo en memoria — reemplazar con BD real) ──
AUTH_DEFAULT_PASSWORD=ChangeMe123!
AUTH_ADMIN_PASSWORD=AdminChange123!

# ── Almacenamiento de adjuntos ───────────────────────────────
STORAGE_PATH=storage/attachments   # Relativo al CWD del backend
MAX_FILE_SIZE_MB=10

# ── SMTP (Notificaciones por correo) ─────────────────────────
# Sin estas variables, QAS usa Ethereal auto-account (preview en consola)
# SMTP_HOST=smtp.tuservicio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario@tuservicio.com
# SMTP_PASS=contraseña-smtp
# SMTP_FROM="PGI Sistema" <noreply@tudominio.com>
